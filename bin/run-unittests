#!/bin/bash

set -eo pipefail

echo "Running fixture-free JVM unit tests"

clojure -M:ci \
	-e integration \
	-n ansatz.export.parser-test \
	-n ansatz.export.replay-test \
	-n ansatz.export.storage-test \
	-n ansatz.kernel.reducer-test \
	-n ansatz.kernel.typechecker-test \
	-n ansatz.surface.lean-test \
	-n ansatz.surface.pp-test \
	-n ansatz.theory.convergence-test \
	-n ansatz.bundled-init-test

echo
echo "bundled-init-test exercises the zero-setup (a/init!) path from the in-jar medium tier."
echo "Integration tests requiring the FULL test-data store are not part of the default CI unit suite."
